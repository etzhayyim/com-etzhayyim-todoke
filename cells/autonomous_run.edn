{:cell/id "autonomous_run"
 :cell/glyph "走行"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/node "judah"
 :cell/doc "Execute the validated lastMileRoute by delegating perception->planning->control to the kami-autodrive GNC crate (ADR-2606010600, VehicleClass::Car / sidewalk variant). Holds the SAE-L4 ceiling + sidewalk-speed envelope at runtime; emergency-stop + replan on obstacle. R0 = cell .edn definition only; live actuation is Council Lv6+ + operator gated (G9) and Transparent-Force bound (every actuation command an on-chain Datom)."
 :cell/entry "cells/autonomous_run/cell.py"
 :cell/handler "AutonomousRunCell"
 :cell/state-graph
 {:nodes [:armed :cruising :obstacle-replan :arrived :run-logged] :entry :armed
  :edges [[:armed :cruising] [:cruising :obstacle-replan] [:obstacle-replan :cruising]
          [:cruising :arrived] [:arrived :run-logged] [:run-logged :end]]}
 :cell/llm {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/gates ["G1" "G4" "G7" "G9" "G12"]
