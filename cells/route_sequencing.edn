{:cell/id "route_sequencing"
 :cell/glyph "順路"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/node "joseph"
 :cell/doc "Turn an accepted deliveryJob into a safety-validated lastMileRoute. Stop sequencing (NN + 2-opt) is the SAME algorithm as the Rust todoke-route crate (one model, two runtimes — via methods.last_mile). G7 safety envelope is a hard refusal: speed over the sidewalk cap, a vehicular-road stop (N2), or SAE level > 4 (N2) raises rather than yields a route. FULLY CODED at R0 (state machine + tests)."
 :cell/entry "cells/route_sequencing/cell.py"
 :cell/handler "RouteSequencingCell"
 :cell/state-graph
 {:nodes [:job-loaded :envelope-checked :sequenced :route-emitted] :entry :job-loaded
  :edges [[:job-loaded :envelope-checked] [:envelope-checked :sequenced] [:envelope-checked :refused]
          [:sequenced :route-emitted] [:route-emitted :end] [:refused :end]]}
 :cell/llm {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/gates ["G4" "G7" "G11"]
 :cell/kotoba {:reads [:job/record] :writes [:route/record :route/order :route/length-m]}}
