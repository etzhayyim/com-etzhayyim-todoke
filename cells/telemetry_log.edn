{:cell/id "telemetry_log"
 :cell/glyph "記録"
 :cell/kind :langgraph
 :cell/runtime :wasm
 :cell/node "levi"
 :cell/doc "Assemble the full mission record (route + energy + safety flags + handoff proof ref) into a kotoba EAVT missionCompleteRecord with an IPFS CID, replayable as-of history (非終末論 — no terminal 'consumed' state). G11 kotoba-EAVT-native + G10 sourcing-honesty. R0 = cell .edn definition only."
 :cell/entry "cells/telemetry_log/cell.py"
 :cell/handler "TelemetryLogCell"
 :cell/state-graph
 {:nodes [:gathered :hashed :pinned :record-emitted] :entry :gathered
  :edges [[:gathered :hashed] [:hashed :pinned] [:pinned :record-emitted] [:record-emitted :end]]}
 :cell/llm {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/gates ["G10" "G11"]
 :cell/kotoba {:reads [:run/telemetry :handoff/proof] :writes [:mission/record :mission/cid]}}
