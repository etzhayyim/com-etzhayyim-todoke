{:lexicon 1
 :id "com.etzhayyim.todoke.missionCompleteRecord"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["jobId" "routeLengthM" "energyWh" "safetyStatus" "handoffProofRef" "cid" "createdAt"]
    :properties
    {:jobId {:type "string"}
     :routeLengthM {:type "number" :minimum 0}
     :energyWh {:type "number" :minimum 0 :description "energy used this run (transparency)"}
     :safetyStatus {:type "string" :enum ["ok" "obstacle-replanned" "emergency-stopped" "aborted"]}
     :handoffProofRef {:type "string" :description "ref to the handoffProof record (G8/G12/G13)"}
     :cid {:type "string" :description "IPFS CID of the mission telemetry blob (G11)"}
     :displacementCohortRef {:type "string" :description "G2: tenure-weighted Displacement-Dividend cohort the freed courier role belongs to (ADR-2606032130)"}
     :createdAt {:type "string" :format "datetime"}}}}}}
