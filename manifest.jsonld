  "purpose": "Last-mile ('one-mile') autonomous delivery — curb-to-door small-payload transport that closes the gap between wadachi inter-site ground autonomy and the recipient's door. Consumes kami-autodrive GNC; the no-gig delivery limb of okaimono; couples to the courier Displacement Dividend.",
  "fleet": [
    { "id": "hakobi", "glyph": "運び", "role": "sidewalk last-mile delivery rover (curb-to-door, <=25 kg)" },
    { "id": "tobira", "glyph": "扉", "role": "smart parcel-locker dock (curb hand-off / pickup)" },
    { "id": "meyasu", "glyph": "目安", "role": "perception + telemetry pod (on-device only, G8)" },
    { "id": "tedori", "glyph": "手取", "role": "load/unload manipulator (curb <-> rover bay)" }
  ],
  "cells": [
