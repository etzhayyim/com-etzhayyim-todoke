{
  "lexicon": 1,
  "id": "com.etzhayyim.todoke.lastMileRoute",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "jobId",
          "order",
          "lengthM",
          "saeLevel",
          "envelopeOk",
          "createdAt"
        ],
        "properties": {
          "jobId": {
            "type": "string"
          },
          "order": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "stop ids in visiting order (depot first); from todoke-route NN+2-opt"
          },
          "lengthM": {
            "type": "number",
            "minimum": 0,
            "description": "total open-path length in metres"
          },
          "saeLevel": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4,
            "description": "N2: SAE autonomy ceiling = 4 (Level 5 disallowed)"
          },
          "saeWithinCeiling": {
            "type": "boolean",
            "const": true,
            "description": "N2 invariant — always true (enforced by the safety envelope)"
          },
          "commandedMps": {
            "type": "number",
            "minimum": 0,
            "maximum": 4.2,
            "description": "G7: commanded speed; <= per-zone cap (sidewalk 1.8 / bike-lane 4.2)"
          },
          "envelopeOk": {
            "type": "boolean",
            "description": "G7: safety-envelope gate result (false => no route was produced)"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
