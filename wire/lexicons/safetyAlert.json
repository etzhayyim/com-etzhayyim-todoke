{
  "lexicon": 1,
  "id": "com.etzhayyim.todoke.safetyAlert",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "jobId",
          "kind",
          "detail",
          "createdAt"
        ],
        "properties": {
          "jobId": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "sae-level-too-high",
              "zone-outside-odd",
              "speed-exceeds-zone-cap",
              "obstacle-emergency-stop",
              "consent-missing",
              "forbidden-proof-kind"
            ],
            "description": "mirrors the Rust EnvelopeViolation variants + runtime G8/G13 refusals"
          },
          "detail": {
            "type": "string",
            "description": "human-readable refusal reason (auditable)"
          },
          "stop": {
            "type": "integer",
            "description": "offending stop id, when applicable"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
